    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst raw = typeof item.text === 'string' ? item.text : typeof item.output === 'string' ? item.output : '';\nlet stripped = String(raw).replace(/^```(?:json)?\\s*/i, '').replace(/```\\s*$/i, '').trim();\nlet data = null;\ntry { data = JSON.parse(stripped); } catch (e) {\n  const m = stripped.match(/\\{[\\s\\S]*\\}/);\n  if (m) { try { data = JSON.parse(m[0]); } catch (e2) {} }\n}\nif (data && data.report && typeof data.report === 'object') data = data.report;\nconst fallback = {\n  contract_type: 'unknown',\n  routing_decision: 'reviewer_queue',\n  jurisdiction: 'unknown',\n  parties: [],\n  overall_risk: 'Medium',\n  findings: [],\n  similar_regulations: [],\n  rag_insight: '',\n  enrichment_notes: 'Could not parse final report JSON.',\n  confidence: 0,\n  parse_error: true\n};\nif (!data || typeof data !== 'object') {\n  return [{ json: { ...fallback, raw_preview: String(raw).slice(0, 800) } }];\n}\nconst risk = data.overall_risk || 'Medium';\nif (!data.routing_decision) {\n  data.routing_decision = risk === 'High' ? 'escalation' : risk === 'Low' ? 'auto_file' : 'reviewer_queue';\n}\nreturn [{ json: data }];"

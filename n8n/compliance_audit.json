    {
      "parameters": {
        "prompt": "={{ 'You extract structured fields from a regulatory contract submission. Reply with one JSON object only — no markdown, no triple-backtick code fences, no text before or after the JSON.\\n\\nUse exactly these keys and types:\\n- contract_type (string): MSA | DPA | NDA | SLA | Employment | Vendor | other\\n- parties (array of strings): company names; [] if none\\n- jurisdiction (string): e.g. EU, US Federal, UK; unknown if not stated\\n- sensitive_topics (array of strings): e.g. data_processing, liability, termination; [] if none\\n- key_concerns (array of strings): up to 5 short risk phrases; [] if none\\n- routing_decision (string): escalation | reviewer_queue | auto_file — infer from severity of concerns (escalation = serious GDPR/SOX gaps)\\n\\nContract description:\\n' + $('Node 1 — Webhook Trigger').item.json.body.description + '\\n\\nRespond with JSON only.' }}"
      },
      "id": "351cdd8b-7513-4950-b771-9ba516991146",
      "name": "Node 4 — Extract contract (LLM)",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1,
      "position": [
        -1360,
        1440
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst raw = typeof item.text === 'string' ? item.text : typeof item.output === 'string' ? item.output : '';\nlet stripped = String(raw).replace(/^```(?:json)?\\s*/i, '').replace(/```\\s*$/i, '').trim();\nlet data = null;\ntry { data = JSON.parse(stripped); } catch (e) {\n  const m = stripped.match(/\\{[\\s\\S]*\\}/);\n  if (m) { try { data = JSON.parse(m[0]); } catch (e2) {} }\n}\nfunction arr(v) {\n  if (Array.isArray(v)) return v.slice(0, 8).map(String);\n  if (typeof v === 'string' && v.includes(',')) return v.split(',').map(s => s.trim()).filter(Boolean).slice(0, 8);\n  if (v == null || v === '') return [];\n  return [String(v)];\n}\nif (!data || typeof data !== 'object') {\n  return [{ json: { output: null, extract_error: true, raw_preview: String(raw).slice(0, 500) } }];\n}\nconst rd = ['escalation','reviewer_queue','auto_file'].includes(data.routing_decision) ? data.routing_decision : 'reviewer_queue';\nreturn [{ json: { output: {\n  contract_type: data.contract_type ?? 'other',\n  parties: arr(data.parties),\n  jurisdiction: data.jurisdiction ?? 'unknown',\n  sensitive_topics: arr(data.sensitive_topics),\n  key_concerns: arr(data.key_concerns).slice(0, 5),\n  routing_decision: rd\n} } }];"
      },
      "id": "67e49051-d3ae-4dfd-a819-ddb3ed4a8b9f",
      "name": "Node 4b — Parse extracted JSON",
      "type": "n8n-nodes-base.code",

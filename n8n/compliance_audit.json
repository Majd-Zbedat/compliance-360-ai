      "position": [
        -1120,
        1632
      ]
    },
    {
      "parameters": {
        "modelName": "models/gemini-2.5-pro",
        "options": {}
      },
      "id": "fbf0d124-8579-4335-82d2-8b33ae7c09ea",
      "name": "Gemini Chat Model — Agent",

# =====================================================================
# AI-Native Regulatory Document Auditor - Environment Variables
# Copy this file to .env and fill in real values.
# =====================================================================

# ---------- External LLM (used by guardrails + langgraph agent) -------
# Provide ONE of the following. If neither is set, services fall back
# to a deterministic rule-based stub so the demo still runs offline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---------- Service URLs (used by the orchestrator) -------------------
RAG_SERVICE_URL=http://localhost:8001
DOC_ANALYZER_SERVICE_URL=http://localhost:8002
GUARDRAILS_SERVICE_URL=http://localhost:8003
LANGGRAPH_AGENT_SERVICE_URL=http://localhost:8004
ORCHESTRATOR_URL=http://localhost:8000

# ---------- n8n (Layer 2 orchestration) -------------------------------
# When set, POST /audits on the orchestrator forwards here. Leave empty to
# use the in-process Python pipeline instead.
N8N_WEBHOOK_URL=http://localhost:9090/webhook/compliance-audit
N8N_REQUEST_TIMEOUT_S=180
# Fall back to in-process Python pipeline when n8n returns an empty webhook body.
N8N_FALLBACK_TO_PYTHON=true
N8N_REQUEST_TIMEOUT_S=180

# ---------- ChromaDB --------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_REGULATIONS_COLLECTION=regulations
CHROMA_CONTRACTS_COLLECTION=contracts

# ---------- Embeddings -----------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---------- Orchestrator DB ------------------------------------------
# SQLite for the demo. Swap to PostgreSQL with e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/auditor
DATABASE_URL=sqlite:///./data/auditor.db

# ---------- Frontend --------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
